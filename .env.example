# ==============================================================================
# Required
# ==============================================================================

# Google Gemini API key — used by all agents (gemini-2.5-flash, gemini-2.5-flash-lite)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ==============================================================================
# Optional
# ==============================================================================

# Mastra Cloud access token — enables sending traces to Mastra Cloud
# Leave empty to disable cloud telemetry (local traces via DefaultExporter still work)
# MASTRA_CLOUD_ACCESS_TOKEN=

# Log level for PinoLogger (default: info)
# Valid values: debug | info | warn | error
# LOG_LEVEL=info
